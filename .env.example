VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-publishable-key
# Optional compatibility aliases. Vite exposes these because vite.config.ts
# explicitly includes NEXT_PUBLIC_ in envPrefix.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-publishable-key

# Frontend public origin used by canonical URLs and payment redirects.
# Keep this aligned with PUBLIC_APP_URL in production.
VITE_APP_PUBLIC_URL=http://localhost:5173

# Browser-facing API origin.
# Use your API domain in production, for example https://api.your-domain.com.
VITE_API_BASE_URL=http://localhost:8787

VITE_ADMIN_ALERT_EMAIL=admin@your-domain.com
VITE_SUPPORT_WHATSAPP=6281234567890

# Keep false/empty for production. Set true only when intentionally running the old local demo flow.
VITE_DEMO_MODE=false

SUPABASE_SERVICE_ROLE_KEY=sb_secret_your-service-role-key
XENDIT_SECRET_KEY=xnd_development_your-secret-key
XENDIT_WEBHOOK_TOKEN=your-xendit-callback-token
XENDIT_IS_PRODUCTION=false
ACCOUNT_ENCRYPTION_KEY=base64-32-byte-key
STOCK_HASH_SECRET=change-this-stock-hmac-secret
ADMIN_SESSION_SECRET=change-this-admin-session-secret
API_PORT=8787

# Backend public origin used for redirects from invoice/topup flows.
# Keep this aligned with VITE_APP_PUBLIC_URL in production.
PUBLIC_APP_URL=http://localhost:5173

# Browser origin allowed by the API.
CORS_ORIGIN=http://localhost:5173

ADMIN_ALERT_EMAIL=admin@your-domain.com
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password

# Cloudflare / custom-domain overrides:
# VITE_API_BASE_URL=https://api.your-domain.com
# VITE_APP_PUBLIC_URL=https://your-domain.com
# PUBLIC_APP_URL=https://your-domain.com
# CORS_ORIGIN=https://your-domain.com
