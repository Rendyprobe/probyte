VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-publishable-key
# Optional compatibility aliases. Vite exposes these because vite.config.ts
# explicitly includes NEXT_PUBLIC_ in envPrefix.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-publishable-key
VITE_APP_PUBLIC_URL=https://your-domain.com
VITE_API_BASE_URL=http://localhost:8787
VITE_ADMIN_ALERT_EMAIL=admin@your-domain.com

SUPABASE_SERVICE_ROLE_KEY=sb_secret_your-service-role-key
XENDIT_SECRET_KEY=xnd_development_your-secret-key
XENDIT_WEBHOOK_TOKEN=your-xendit-callback-token
XENDIT_IS_PRODUCTION=false
ACCOUNT_ENCRYPTION_KEY=base64-32-byte-key
STOCK_HASH_SECRET=change-this-stock-hmac-secret
ADMIN_SESSION_SECRET=change-this-admin-session-secret
API_PORT=8787
PUBLIC_APP_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

ADMIN_ALERT_EMAIL=admin@your-domain.com
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
